# =============================================================================
# Enwealth E-Board Portal — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in every value before running the project.
#
#   cp .env.example .env
#
# NEVER commit your real .env file to version control.
# All variables are read via python-decouple (config() / Csv()).
# =============================================================================


# -----------------------------------------------------------------------------
# Django Core
# -----------------------------------------------------------------------------
SECRET_KEY=your-very-long-random-secret-key-change-me-in-production
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production

# Comma-separated list of hosts Django will serve (no spaces around commas)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Full public URL used in email links, e-signatures, etc. (no trailing slash)
SITE_URL=https://yourdomain.com


# -----------------------------------------------------------------------------
# Database — PostgreSQL
# -----------------------------------------------------------------------------
DB_NAME=enwealth_eboard
DB_USER=enwealth_user
DB_PASSWORD=a-strong-database-password
DB_HOST=localhost
# DB_HOST=db         # use this when running under Docker Compose
DB_PORT=5432


# -----------------------------------------------------------------------------
# Celery — Redis Broker & Result Backend
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# When running under Docker Compose, use the service name instead:
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/1


# -----------------------------------------------------------------------------
# Email — SMTP (production)
# Use django.core.mail.backends.console.EmailBackend for local development
# (that is already set in config/settings/development.py automatically).
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.mailgun.org
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=postmaster@mg.yourdomain.com
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=Enwealth E-Board <noreply@yourdomain.com>


# -----------------------------------------------------------------------------
# CSRF & Trusted Origins
# Comma-separated full origins (scheme + host [+ port])
# -----------------------------------------------------------------------------
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com


# -----------------------------------------------------------------------------
# Session
# How long (in seconds) a session remains valid.
# Default: 3600 (1 hour). Adjust to suit your security policy.
# -----------------------------------------------------------------------------
SESSION_COOKIE_AGE=3600


# -----------------------------------------------------------------------------
# Authentication / Security
# Maximum failed login attempts before an account is locked out.
# LOCKOUT_DURATION_MINUTES: how long the lockout lasts.
# -----------------------------------------------------------------------------
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30


# =============================================================================
# Optional / Advanced
# =============================================================================

# -----------------------------------------------------------------------------
# Sentry — Error Tracking (production only, requires sentry-sdk[django])
# Leave blank to disable Sentry.
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0


# -----------------------------------------------------------------------------
# AWS S3 — Media File Storage (optional, requires django-storages[s3] + boto3)
# Set USE_S3=True to switch MEDIA_ROOT to an S3 bucket.
# -----------------------------------------------------------------------------
# USE_S3=False
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_STORAGE_BUCKET_NAME=enwealth-media
# AWS_S3_REGION_NAME=af-south-1
# AWS_S3_CUSTOM_DOMAIN=


# -----------------------------------------------------------------------------
# Development overrides
# Uncomment these when working locally with config/settings/development.py
# -----------------------------------------------------------------------------
# DEBUG=True
# DJANGO_SETTINGS_MODULE=config.settings.development
# ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# SITE_URL=http://localhost:8000
# CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# DB_HOST=localhost
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1
