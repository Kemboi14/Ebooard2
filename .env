# Django
SECRET_KEY=django-insecure-dev-secret-key-for-enwealth-eboard-platform-2026
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1,eboard.enwealth.co.ke

# Database — PostgreSQL installed natively (not in Docker)
DB_NAME=enwealth_eboard
DB_USER=enwealth_user
DB_PASSWORD=dev_password
DB_HOST=localhost
DB_PORT=5432

# Redis — installed natively (not in Docker)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@enwealth.co.ke
EMAIL_HOST_PASSWORD=your-gmail-app-password

# Security
SESSION_COOKIE_AGE=3600
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
