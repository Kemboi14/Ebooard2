{% extends 'base/base.html' %}

{% block title %}Dashboard{% endblock %}

{% block page_title %}Dashboard{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto">
  <!-- Welcome Header -->
  <div class="mb-8">
    <h1 class="text-2xl font-bold" style="color: #2d1b5e;">
      Welcome back, {{ user.first_name }}!
    </h1>
    <p class="text-gray-600 mt-1">
      Here's what's happening with your board activities today.
    </p>
  </div>

  <!-- Stats Row - 4 Cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    {% if user.role == 'board_member' %}
      <!-- Board Member Stats -->
      <div class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #e8f5d0;">
          <svg class="w-6 h-6" style="color: #7dc143;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold" style="color: #2d1b5e;">{{ dashboard_stats.meetings_this_month }}</p>
          <p class="text-sm text-gray-600">Meetings This Month</p>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #fef3c7;">
          <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold" style="color: #2d1b5e;">{{ dashboard_stats.pending_actions }}</p>
          <p class="text-sm text-gray-600">Pending Actions</p>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #dbeafe;">
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold" style="color: #2d1b5e;">{{ dashboard_stats.documents_to_review }}</p>
          <p class="text-sm text-gray-600">Documents to Review</p>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #f3f4f6;">
          <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold" style="color: #2d1b5e;">{{ unread_notifications_count }}</p>
          <p class="text-sm text-gray-600">Notifications</p>
        </div>
      </div>

    {% elif user.role == 'company_secretary' %}
      <!-- Company Secretary Stats -->
      <div class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #e8f5d0;">
          <svg class="w-6 h-6" style="color: #7dc143;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold" style="color: #2d1b5e;">{{ dashboard_stats.total_meetings }}</p>
          <p class="text-sm text-gray-600">Total Meetings</p>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #fef3c7;">
          <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold" style="color: #2d1b5e;">{{ dashboard_stats.draft_resolutions }}</p>
          <p class="text-sm text-gray-600">Draft Resolutions</p>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #fee2e2;">
          <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold" style="color: #2d1b5e;">{{ dashboard_stats.pending_minutes }}</p>
          <p class="text-sm text-gray-600">Pending Minutes</p>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #f3f4f6;">
          <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold" style="color: #2d1b5e;">{{ unread_notifications_count }}</p>
          <p class="text-sm text-gray-600">Notifications</p>
        </div>
      </div>

    {% elif user.role == 'it_administrator' %}
      <!-- IT Administrator Stats -->
      <div class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #e8f5d0;">
          <svg class="w-6 h-6" style="color: #7dc143;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold" style="color: #2d1b5e;">{{ dashboard_stats.total_users }}</p>
          <p class="text-sm text-gray-600">Total Users</p>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #dbeafe;">
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold" style="color: #2d1b5e;">{{ dashboard_stats.active_users }}</p>
          <p class="text-sm text-gray-600">Active Users (30d)</p>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #d1fae5;">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold" style="color: #2d1b5e;">{{ dashboard_stats.system_health }}%</p>
          <p class="text-sm text-gray-600">System Health</p>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #fef3c7;">
          <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold" style="color: #2d1b5e;">{{ failed_logins_today }}</p>
          <p class="text-sm text-gray-600">Failed Logins Today</p>
        </div>
      </div>

    {% elif user.role == 'compliance_officer' %}
      <!-- Compliance Officer Stats -->
      <div class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #fee2e2;">
          <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.502 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold" style="color: #2d1b5e;">{{ risk_counts.critical }}</p>
          <p class="text-sm text-gray-600">Critical Risks</p>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #fed7aa;">
          <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.502 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold" style="color: #2d1b5e;">{{ risk_counts.high }}</p>
          <p class="text-sm text-gray-600">High Risks</p>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #fef3c7;">
          <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.502 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold" style="color: #2d1b5e;">{{ risk_counts.medium }}</p>
          <p class="text-sm text-gray-600">Medium Risks</p>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #d1fae5;">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold" style="color: #2d1b5e;">{{ risk_counts.low }}</p>
          <p class="text-sm text-gray-600">Low Risks</p>
        </div>
      </div>

    {% else %}
      <!-- Default stats for other roles -->
      <div class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #e8f5d0;">
          <svg class="w-6 h-6" style="color: #7dc143;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold" style="color: #2d1b5e;">--</p>
          <p class="text-sm text-gray-600">Dashboard Stats</p>
        </div>
      </div>
    {% endif %}
  </div>

  <!-- Main Content Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Left Column - Main Content (2/3 width) -->
    <div class="lg:col-span-2 space-y-6">
      {% if user.role == 'board_member' %}
        <!-- Board Member: Upcoming Meetings -->
        <div class="bg-white rounded-xl shadow-sm p-6">
          <h2 class="text-lg font-semibold mb-4" style="color: #2d1b5e;">Upcoming Meetings</h2>
          <div class="space-y-3">
            {% for meeting in upcoming_meetings %}
              <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg hover:bg-gray-50">
                <div class="flex-1">
                  <h3 class="font-medium text-gray-900">{{ meeting.title }}</h3>
                  <p class="text-sm text-gray-600">{{ meeting.scheduled_date|date:"M d, Y" }} at {{ meeting.scheduled_date|time:"g:i A" }}</p>
                </div>
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                  {{ meeting.get_status_display }}
                </span>
              </div>
            {% empty %}
              <div class="text-center py-8 text-gray-500">
                <svg class="w-12 h-12 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <p>No upcoming meetings scheduled</p>
              </div>
            {% endfor %}
          </div>
        </div>

        <!-- Board Member: Pending Actions -->
        <div class="bg-white rounded-xl shadow-sm p-6">
          <h2 class="text-lg font-semibold mb-4" style="color: #2d1b5e;">Pending Actions</h2>
          <div class="space-y-3">
            <div class="text-center py-8 text-gray-500">
              <svg class="w-12 h-12 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
              <p>No pending actions at this time</p>
            </div>
          </div>
        </div>

      {% elif user.role == 'company_secretary' %}
        <!-- Company Secretary: All Meetings -->
        <div class="bg-white rounded-xl shadow-sm p-6">
          <h2 class="text-lg font-semibold mb-4" style="color: #2d1b5e;">All Upcoming Meetings</h2>
          <div class="space-y-3">
            {% for meeting in all_upcoming_meetings %}
              <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg hover:bg-gray-50">
                <div class="flex-1">
                  <h3 class="font-medium text-gray-900">{{ meeting.title }}</h3>
                  <p class="text-sm text-gray-600">{{ meeting.scheduled_date|date:"M d, Y" }} at {{ meeting.scheduled_date|time:"g:i A" }}</p>
                </div>
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                  {{ meeting.get_status_display }}
                </span>
              </div>
            {% empty %}
              <div class="text-center py-8 text-gray-500">
                <svg class="w-12 h-12 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <p>No meetings scheduled</p>
              </div>
            {% endfor %}
          </div>
        </div>

        <!-- Company Secretary: Draft Resolutions -->
        <div class="bg-white rounded-xl shadow-sm p-6">
          <h2 class="text-lg font-semibold mb-4" style="color: #2d1b5e;">Draft Resolutions</h2>
          <div class="space-y-3">
            {% for resolution in draft_resolutions %}
              <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg hover:bg-gray-50">
                <div class="flex-1">
                  <h3 class="font-medium text-gray-900">{{ resolution.title }}</h3>
                  <p class="text-sm text-gray-600">Created {{ resolution.created_at|date:"M d, Y" }}</p>
                </div>
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                  Draft
                </span>
              </div>
            {% empty %}
              <div class="text-center py-8 text-gray-500">
                <svg class="w-12 h-12 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <p>No draft resolutions</p>
              </div>
            {% endfor %}
          </div>
        </div>

      {% elif user.role == 'it_administrator' %}
        <!-- IT Administrator: Recent Activity -->
        <div class="bg-white rounded-xl shadow-sm p-6">
          <h2 class="text-lg font-semibold mb-4" style="color: #2d1b5e;">Recent System Activity</h2>
          <div class="space-y-3">
            {% for activity in recent_activity %}
              <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg">
                <div class="flex items-center gap-3">
                  <div class="w-2 h-2 rounded-full" style="background-color: #7dc143;"></div>
                  <div>
                    <p class="text-sm font-medium text-gray-900">{{ activity.action }}</p>
                    <p class="text-xs text-gray-600">{{ activity.timestamp|timesince }} ago</p>
                  </div>
                </div>
                <span class="text-xs text-gray-500">{{ activity.user_email }}</span>
              </div>
            {% empty %}
              <div class="text-center py-8 text-gray-500">
                <svg class="w-12 h-12 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p>No recent activity</p>
              </div>
            {% endfor %}
          </div>
        </div>

        <!-- IT Administrator: System Health -->
        <div class="bg-white rounded-xl shadow-sm p-6">
          <h2 class="text-lg font-semibold mb-4" style="color: #2d1b5e;">System Health</h2>
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-600">Database Status</span>
              <span class="px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">Healthy</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-600">Redis Cache</span>
              <span class="px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">Connected</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-600">Storage Usage</span>
              <span class="text-sm text-gray-900">{{ storage_used }} GB used</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-600">Failed Logins Today</span>
              <span class="text-sm text-gray-900">{{ failed_logins_today }}</span>
            </div>
          </div>
        </div>

      {% else %}
        <!-- Default content for other roles -->
        <div class="bg-white rounded-xl shadow-sm p-6">
          <h2 class="text-lg font-semibold mb-4" style="color: #2d1b5e;">Welcome to Your Dashboard</h2>
          <div class="text-center py-8 text-gray-500">
            <svg class="w-12 h-12 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            <p>Your dashboard content will be available as we implement more modules.</p>
            <p class="text-sm mt-2">Role: <span class="font-medium">{{ user.get_role_display }}</span></p>
          </div>
        </div>
      {% endif %}
    </div>

    <!-- Right Column - Quick Actions & Activity (1/3 width) -->
    <div class="space-y-6">
      <!-- Quick Actions -->
      <div class="bg-white rounded-xl shadow-sm p-6">
        <h2 class="text-lg font-semibold mb-4" style="color: #2d1b5e;">Quick Actions</h2>
        <div class="space-y-3">
          {% if user.role == 'company_secretary' %}
            <a href="#" class="block w-full text-center px-4 py-2 rounded-lg text-white text-sm font-medium transition-colors"
               style="background:#7dc143;"
               onmouseover="this.style.backgroundColor='#5a8a3c'"
               onmouseout="this.style.backgroundColor='#7dc143'">
              Schedule Meeting
            </a>
            <a href="#" class="block w-full text-center px-4 py-2 rounded-lg text-white text-sm font-medium"
               style="background:#2d7a6e;">
              Create Resolution
            </a>
          {% elif user.role == 'it_administrator' %}
            <a href="{% url 'admin:index' %}" class="block w-full text-center px-4 py-2 rounded-lg text-white text-sm font-medium transition-colors"
               style="background:#7dc143;"
               onmouseover="this.style.backgroundColor='#5a8a3c'"
               onmouseout="this.style.backgroundColor='#7dc143'">
              Admin Panel
            </a>
            <a href="#" class="block w-full text-center px-4 py-2 rounded-lg text-white text-sm font-medium"
               style="background:#2d7a6e;">
              User Management
            </a>
          {% elif user.role == 'compliance_officer' %}
            <a href="#" class="block w-full text-center px-4 py-2 rounded-lg text-white text-sm font-medium transition-colors"
               style="background:#7dc143;"
               onmouseover="this.style.backgroundColor='#5a8a3c'"
               onmouseout="this.style.backgroundColor='#7dc143'">
              Risk Assessment
            </a>
            <a href="#" class="block w-full text-center px-4 py-2 rounded-lg text-white text-sm font-medium"
               style="background:#2d7a6e;">
              Policy Review
            </a>
          {% else %}
            <a href="{% url 'accounts:profile' %}" class="block w-full text-center px-4 py-2 rounded-lg text-white text-sm font-medium transition-colors"
               style="background:#7dc143;"
               onmouseover="this.style.backgroundColor='#5a8a3c'"
               onmouseout="this.style.backgroundColor='#7dc143'">
              Update Profile
            </a>
            <a href="{% url 'accounts:change_password' %}" class="block w-full text-center px-4 py-2 rounded-lg text-white text-sm font-medium"
               style="background:#2d7a6e;">
              Change Password
            </a>
          {% endif %}
        </div>
      </div>

      <!-- Recent Activity -->
      <div class="bg-white rounded-xl shadow-sm p-6">
        <h2 class="text-lg font-semibold mb-4" style="color: #2d1b5e;">Recent Activity</h2>
        <div class="space-y-3">
          {% for notification in recent_notifications %}
            <div class="flex items-start gap-3">
              <div class="w-2 h-2 rounded-full mt-2" style="background-color: #7dc143;"></div>
              <div class="flex-1">
                <p class="text-sm text-gray-900">{{ notification.title }}</p>
                <p class="text-xs text-gray-600">{{ notification.created_at|timesince }} ago</p>
              </div>
            </div>
          {% empty %}
            <div class="text-center py-4 text-gray-500">
              <svg class="w-8 h-8 mx-auto mb-2 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
              </svg>
              <p class="text-sm">No recent activity</p>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
